# Normalize line endings to LF in the repo; check out platform-native on Windows.
# Prevents CRLF/LF churn and Prettier `endOfLine` failures across the team.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary
*.keystore binary
