# Production environment for docker-compose.prod.yml.
# Copy to .env on the host and fill in real values. NEVER commit the real .env.

# ── Images ───────────────────────────────────────────────────────────────────
# Where the deploy pipeline publishes images, and which tag to run.
IMAGE_REGISTRY=ghcr.io/ismetcahangirov
IMAGE_TAG=latest

# ── Public URLs / domain ─────────────────────────────────────────────────────
# Root domain served by the edge proxy. The admin panel is served at
# admin.<DOMAIN>; the API + landing at <DOMAIN>.
DOMAIN=tutora.app
# Baked into the admin/web bundles at build time (points clients at the API).
PUBLIC_API_URL=https://tutora.app

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (inside the compose network the host is `postgres`) ─────────────
POSTGRES_USER=tutora
POSTGRES_PASSWORD=change-me-to-a-strong-secret
POSTGRES_DB=tutora
# The API/migrate/backup services derive DATABASE_URL from the values above.

# ── Redis (host is `redis` inside the compose network) ───────────────────────
# REDIS_URL is set to redis://redis:6379 by compose.

# ── JWT auth — use long random strings; rotate regularly ─────────────────────
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Mailer ───────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Tutora <no-reply@tutora.app>

# ── Monitoring (Sentry — #92) ────────────────────────────────────────────────
# All optional — leave empty to disable Sentry. See docs/monitoring.md.
# API (server-side, injected via env_file):
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Client DSNs baked into the admin/web bundles at BUILD time (public, per-project):
ADMIN_SENTRY_DSN=
WEB_SENTRY_DSN=

# ── Backups (db-backup service) ──────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400
