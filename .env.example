# Copy to .env and fill in. Real .env files are gitignored — never commit secrets.

# ── API (tutora-api) — server-side only, NEVER exposed to clients ────────────
NODE_ENV=development
PORT=3000

# Data stores (provided by docker-compose in #7)
DATABASE_URL=postgresql://tutora:tutora@localhost:5432/tutora
REDIS_URL=redis://localhost:6379

# JWT auth — use long random strings; rotate in production
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Public client vars (safe to ship in the bundle) ─────────────────────────
# Mobile (Expo) — only EXPO_PUBLIC_* is inlined
EXPO_PUBLIC_API_URL=http://localhost:3000
# Admin (Vite) — only VITE_* is exposed
VITE_API_URL=http://localhost:3000
# Landing (Next.js) — only NEXT_PUBLIC_* is exposed
NEXT_PUBLIC_API_URL=http://localhost:3000
