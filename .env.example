# Copy to .env and fill in. Real .env files are gitignored — never commit secrets.

# ── API (tutora-api) — server-side only, NEVER exposed to clients ────────────
NODE_ENV=development
PORT=3000

# Data stores — the URLs below match the docker-compose defaults
DATABASE_URL=postgresql://tutora:tutora@localhost:5432/tutora
REDIS_URL=redis://localhost:6379

# docker-compose overrides (optional; defaults shown)
POSTGRES_USER=tutora
POSTGRES_PASSWORD=tutora
POSTGRES_DB=tutora
POSTGRES_PORT=5432
REDIS_PORT=6379

# JWT auth — use long random strings; rotate in production
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Mailer (localized transactional email) — optional. Leave SMTP_HOST unset in
# dev/test to use a no-network transport (emails are composed but not delivered).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Tutora <no-reply@tutora.app>

# ── Public client vars (safe to ship in the bundle) ─────────────────────────
# Mobile (Expo) — only EXPO_PUBLIC_* is inlined
EXPO_PUBLIC_API_URL=http://localhost:3000
# Admin (Vite) — only VITE_* is exposed
VITE_API_URL=http://localhost:3000
# Landing (Next.js) — only NEXT_PUBLIC_* is exposed
NEXT_PUBLIC_API_URL=http://localhost:3000
