# Copy to apps/tutora-api/.env and fill in. Validated by src/config/env.ts at boot.
NODE_ENV=development
PORT=3000

# Data stores (provided by docker-compose in #7)
DATABASE_URL=postgresql://tutora:tutora@localhost:5432/tutora
REDIS_URL=redis://localhost:6379

# JWT auth — use long random strings (>= 16 chars); rotate in production
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth — the client ID the mobile app's idToken is issued for.
# NOTE: JWT_REFRESH_SECRET above also serves as the HMAC pepper for stored refresh tokens.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Push notifications — Firebase Cloud Messaging service account (#35). Optional:
# leave blank to disable push (in-app notifications still work). Take these from a
# Firebase service-account JSON. Never commit real values — inject via secrets.
# FIREBASE_PRIVATE_KEY keeps its literal "\n" escapes (they are unescaped at boot).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Media uploads — Cloud Storage bucket for signed avatar & certificate uploads
# (#37). Reuses the FIREBASE_* service account above to sign the upload URLs.
# Optional: leave blank to disable uploads (the endpoint returns 503; the rest of
# the API runs). Example: your-project.appspot.com
FIREBASE_STORAGE_BUCKET=
