# Tutora mobile — public runtime config (Expo inlines EXPO_PUBLIC_* at build time).
# Copy to `.env` and fill in. NEVER commit real values or secrets.

# Backend base URL (no trailing slash). Defaults to http://localhost:3000.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth client IDs (issue #22).
# Create OAuth 2.0 clients at https://console.cloud.google.com/apis/credentials.
# The Web client id's audience is what the backend verifies the idToken against.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
